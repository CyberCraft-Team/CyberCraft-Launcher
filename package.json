{
  "name": "cybercraft-launcher",
  "version": "2.1.0",
  "description": "CyberCraft Launcher - Minecraft client",
  "main": "main.js",
  "author": {
    "name": "CyberCraft Team",
    "email": "admin@cybercraft.uz"
  },
  "license": "MIT",
  "homepage": "https://cybercraft.uz",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-store": "^8.1.0",
    "minecraft-launcher-core": "^3.18.1"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.cybercraft.launcher",
    "productName": "CyberCraft Launcher",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "index.html",
      "renderer.js",
      "styles.css"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "tar.gz",
      "category": "Game",
      "icon": "assets/icon.png",
      "maintainer": "CyberCraft Team <admin@cybercraft.uz>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
